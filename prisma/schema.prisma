// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  createdAt DateTime @default(now())
}

model Project {
  id          Int         @id @default(autoincrement())
  displayId   String
  name        String
  description String
  changeLogs  ChangeLog[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now())
}

model ChangeLog {
  id          Int          @id @default(autoincrement())
  project     Project      @relation(fields: [projectId], references: [id])
  projectId   Int
  cvrId       Int
  description String
  status      StatusLookup @relation(fields: [statusId], references: [id])
  statusId    Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now())
}

model StatusLookup {
  id         Int         @id
  status     String
  changelogs ChangeLog[]
}

model PipingGroup {
  id                     Int                @id @default(autoincrement())
  groupNo                Int                @unique
  materialClassification String
  installCode            String
  shopCode               String
  parentCode             String
  weightCode             String
  material               String
  sched                  String
  percentAdder           Float
  values                 PipingGroupValue[]
}

model PipingGroupValue {
  id            Int         @id @default(autoincrement())
  pipingGroup   PipingGroup @relation(fields: [pipingGroupId], references: [id])
  pipingGroupId Int
  size          Float
  value         Float
}

model PipingFactor {
  id             Int                 @id @default(autoincrement())
  discipline     String
  description    String
  code           String
  taskDefinition String
  unit           String
  values         PipingFactorValue[]

  @@unique([discipline, description, code, taskDefinition, unit])
}

model PipingFactorValue {
  id             Int          @id @default(autoincrement())
  pipingFactor   PipingFactor @relation(fields: [pipingFactorId], references: [id])
  pipingFactorId Int
  size           Float
  value          Float?
}

model Role {
  id    Int        @id @default(autoincrement())
  name  String     @unique
  rates RoleRate[]
}

model RoleRate {
  id       Int    @id @default(autoincrement())
  role     Role   @relation(fields: [roleId], references: [id])
  roleId   Int
  schedule String
  rate     Float
}

model CbsItem {
  id                 Int     @id @default(autoincrement())
  l1                 String
  l2                 String
  l3                 String
  l4                 String
  l5                 String
  l6                 String
  name               String
  displayCode        String
  uom                String
  accountDescription String
  l2Description      String?
  core               String?
  coreExtension      String?
  wbs                String?
  p6CostAccount      String?
  gl                 String?
  costTypePC         String?
  costTypeSpectrum   String?
  costCategory       String?
  discipline         String?
  subReporting       String?
  costCode           String  @unique
  description        String?
  displayDescription String?
}
