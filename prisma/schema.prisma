// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  createdAt DateTime @default(now())
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// Append-only audit log. One row per CREATE/DELETE, one row per changed
// field on UPDATE. `projectId` and `actorId` are intentionally plain columns
// (no FK relations) so history survives project or user deletion;
// `actorEmail` is a denormalized snapshot for the same reason.
model AuditEvent {
  id         Int         @id @default(autoincrement())
  entityType String
  entityId   Int
  projectId  Int?
  action     AuditAction
  field      String?
  oldValue   String?
  newValue   String?
  actorId    Int
  actorEmail String
  // Optional free-text note — carries an approval/rejection comment when the
  // event is a workflow status transition.
  note       String?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([projectId, createdAt])
}

// Privilege levels, extensible: add a value here and a rank in ROLE_RANK
// (src/utils/users.ts) to introduce an intermediate level later. APPROVER
// sits between USER and ADMINISTRATOR — it can action approval-workflow
// transitions but has no admin access.
enum UserRole {
  USER
  APPROVER
  ADMINISTRATOR
}

// App user, lazily synced from Clerk on first authenticated request.
// `clerkId` is the Clerk user id; `role` drives role-based access control.
model User {
  id            Int            @id @default(autoincrement())
  clerkId       String         @unique
  email         String         @unique
  role          UserRole       @default(USER)
  // Projects this user is granted access to. Administrators ignore this set
  // and can access every project; see `requireProjectAccess` in users.server.
  projects      Project[]      @relation("UserProjects")
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Per-user inbox entry, emitted on workflow transitions (and, later, comments
// or due-date reminders). One row per recipient — the same transition fans
// out to multiple notifications. Cleaned up when the user is deleted; the
// `projectId` is a plain column (no FK) so a deleted project doesn't blast
// every related notification, mirroring `AuditEvent`'s philosophy.
model Notification {
  id         Int       @id @default(autoincrement())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  projectId  Int?
  entityType String
  entityId   Int
  title      String
  message    String
  actorEmail String    @default("")
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Project {
  id                 Int                 @id @default(autoincrement())
  displayId          String
  name               String
  description        String
  // Optional schedule window — drives the time-linear PV fallback in EVM
  // when a `ReportingPeriod.PeriodMeasurement` doesn't set a manual override.
  // Both nullable so existing projects don't require backfill.
  startDate          DateTime?
  endDate            DateTime?
  changeLogs         ChangeLog[]
  fieldChangeOrders  FieldChangeOrder[]
  allowedFefCbsItems CbsItem[]           @relation("ProjectAllowedFefCbsItems")
  fefRows            FefRow[]
  areas              Area[]
  subcontractors     Subcontractor[]     @relation("ProjectSubcontractors")
  users              User[]              @relation("UserProjects")
  basisInputs        BasisInputs?
  estimateSnapshots  EstimateSnapshot[]
  reportingPeriods   ReportingPeriod[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now())
}

// Subcontractor company. `displayId` is the human-assigned ID code (unique).
// `disciplines` holds discipline ids from src/config/disciplines.ts. Projects
// is a many-to-many: a sub can work multiple projects and a project hires
// multiple subs.
model Subcontractor {
  id          Int       @id @default(autoincrement())
  displayId   String    @unique
  name        String
  description String    @default("")
  disciplines String[]  @default([])
  projects    Project[] @relation("ProjectSubcontractors")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// A physical location on a project. Owned by exactly one project for now
// (one-to-many); could become a shared pool (many-to-many) later.
model Area {
  id          Int      @id @default(autoincrement())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   Int
  displayId   String
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

enum FefSection {
  TAKE_OFF
  SUPPORT_LABOR
  MATERIALS
}

model FefRow {
  id                   Int        @id @default(autoincrement())
  project              Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId            Int
  discipline           String
  section              FefSection
  position             Int
  cbsCode              String     @default("")
  name                 String     @default("")
  description          String     @default("")
  shopField            String     @default("")
  weldGroupDescription String     @default("")
  quantity             String     @default("")
  size                 String     @default("")
  unit                 String     @default("")
  metallurgyCode       String     @default("")
  boreSize             String     @default("")
  role                 String     @default("")
  schedule             String     @default("")
  taskCode             String     @default("")
  laborHours           String     @default("")
  laborRate            String     @default("")
  materialCost         String     @default("")
  equipment            String     @default("")
  notes                String     @default("")
  sub                  String     @default("")
  area                 String     @default("")
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([projectId, discipline, section])
  // Stable identity for ON CONFLICT upsert in `saveFefRows`. Positions are
  // always sequential within a (project, discipline, section); the constraint
  // codifies that invariant so the upsert key is well-defined.
  @@unique([projectId, discipline, section, position])
}

model BasisInputs {
  id                 Int      @id @default(autoincrement())
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId          Int      @unique
  estimateFactor     String   @default("")
  compositeLaborRate String   @default("")
  milestones         Json     @default("[]")
  updatedAt          DateTime @updatedAt
}

model PipingGroup {
  id                     Int                @id @default(autoincrement())
  groupNo                Int                @unique
  materialClassification String
  installCode            String
  shopCode               String
  parentCode             String
  weightCode             String
  material               String
  sched                  String
  percentAdder           Float
  values                 PipingGroupValue[]
}

model PipingGroupValue {
  id            Int         @id @default(autoincrement())
  pipingGroup   PipingGroup @relation(fields: [pipingGroupId], references: [id])
  pipingGroupId Int
  size          Float
  value         Float
}

model PipingFactor {
  id             Int                 @id @default(autoincrement())
  discipline     String
  description    String
  code           String
  taskDefinition String
  unit           String
  values         PipingFactorValue[]

  @@unique([discipline, description, code, taskDefinition, unit])
}

model PipingFactorValue {
  id             Int          @id @default(autoincrement())
  pipingFactor   PipingFactor @relation(fields: [pipingFactorId], references: [id])
  pipingFactorId Int
  size           Float
  value          Float?
}

model Role {
  id    Int        @id @default(autoincrement())
  name  String     @unique
  rates RoleRate[]
}

model RoleRate {
  id       Int    @id @default(autoincrement())
  role     Role   @relation(fields: [roleId], references: [id])
  roleId   Int
  schedule String
  rate     Float
}

enum ChangeStatus {
  REQUESTED
  IN_REVIEW
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXECUTED
  VOID
}

enum ChangeType {
  SCOPE
  COST
  SCHEDULE
  ENGINEERING
  CONSTRUCTION
  PROCUREMENT
  REGULATORY
  OTHER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ChangeLog {
  id                  Int                 @id @default(autoincrement())
  project             Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId           Int
  cvrNumber           String              @default("")
  title               String
  description         String              @default("")
  status              ChangeStatus        @default(REQUESTED)
  type                ChangeType          @default(SCOPE)
  discipline          String              @default("")
  cbsCodes            String[]            @default([])
  originator          String              @default("")
  costImpact          Float               @default(0)
  scheduleDaysImpact  Int                 @default(0)
  laborHoursImpact    Float               @default(0)
  riskLevel           RiskLevel           @default(MEDIUM)
  reasonCode          String              @default("")
  requestedAt         DateTime            @default(now())
  dueDate             DateTime?
  approvedAt          DateTime?
  approver            String              @default("")
  notes               String              @default("")
  // Optional area scope. Holds the Area.id as a string, matching the
  // FefRow.area / FieldChangeOrder.locationArea convention. Empty when the
  // CVR is project-wide (no single area).
  area                String              @default("")
  // User.id of whoever created this CVR. Plain column (no FK) so it survives
  // user deletion; drives the approval workflow's "approver ≠ originator"
  // rule. Null on rows that predate the column.
  createdById         Int?
  fieldChangeOrders   FieldChangeOrder[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([projectId, status])
}

enum FcoStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  LINKED_TO_CVR
  APPROVED
  REJECTED
  IMPLEMENTED
  CLOSED
  VOID
}

enum FcoOriginType {
  FIELD_CONDITION
  RFI_RESPONSE
  DESIGN_OMISSION
  DESIGN_CONFLICT
  OWNER_DIRECTIVE
  SAFETY
  REGULATORY
  WEATHER
  SUBCONTRACTOR
  OTHER
}

enum FcoPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model FieldChangeOrder {
  id                 Int           @id @default(autoincrement())
  project            Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId          Int
  fcoNumber          String        @default("")
  title              String
  description        String        @default("")
  status             FcoStatus     @default(DRAFT)
  originType         FcoOriginType @default(FIELD_CONDITION)
  priority           FcoPriority   @default(NORMAL)
  discipline         String        @default("")
  cbsCodes           String[]      @default([])
  locationArea       String        @default("")
  drawingRefs        String[]      @default([])
  rfiNumbers         String[]      @default([])
  initiatedBy        String        @default("")
  fieldContact       String        @default("")
  estimatedCost      Float         @default(0)
  estimatedHours     Float         @default(0)
  workStopped        Boolean       @default(false)
  photosUrl          String        @default("")
  reasonNarrative    String        @default("")
  resolution         String        @default("")
  notes              String        @default("")
  initiatedAt        DateTime      @default(now())
  neededBy           DateTime?
  closedAt           DateTime?
  linkedCvr          ChangeLog?    @relation(fields: [linkedCvrId], references: [id], onDelete: SetNull)
  linkedCvrId        Int?
  // User.id of whoever raised this FCO. Plain column (no FK) so it survives
  // user deletion; drives the approval workflow's "approver ≠ originator"
  // rule. Null on rows that predate the column.
  createdById        Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([projectId, status])
  @@index([linkedCvrId])
}

// Frozen copy of a project's estimate at a point in time. Captures every
// FefRow and the BasisInputs as JSON so the snapshot survives schema changes
// on either side. Inputs are frozen; the totals are recomputed on view from
// the same `accumulateProjectTotals` the live Summary page uses, so there's
// one source of truth for the aggregation math. Areas + CBS allow-list are
// intentionally NOT snapshotted — they're cheap to recompute live and don't
// change often enough to matter for the "as-bid vs. now" comparison.
model EstimateSnapshot {
  id          Int      @id @default(autoincrement())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   Int
  /// Free-text identity ("v1", "as-bid 2026-04-15", "rev 2 after RFI-042").
  label       String
  notes       String   @default("")
  /// Serialized `FefRow[]` at snapshot time. Whatever shape `prisma.fefRow.findMany`
  /// returns — no schema enforcement here on purpose so this table doesn't
  /// need a migration every time the FefRow column set evolves.
  fefRows     Json
  /// Serialized `BasisInputs` at snapshot time, or null when the project had none.
  basisInputs Json?
  /// Pre-computed `ProjectFefRowTotals` at snapshot creation. Lets read paths
  /// (snapshot detail dialog, EVM period view) skip parsing the heavy
  /// `fefRows` blob and re-running the aggregator on every fetch — snapshots
  /// are immutable so the cached totals can never go stale.
  /// Nullable to keep migration painless: old snapshots fall back to
  /// computing on read. New snapshots always write it.
  totals      Json?
  /// Denormalized for the list view so we don't parse `fefRows` to count.
  rowCount    Int
  /// User.id of whoever clicked "Create snapshot". Plain column (no FK) so it
  /// survives user deletion — mirrors the audit/notifications convention.
  createdById Int?
  createdAt   DateTime @default(now())
  /// Reporting periods that use this snapshot as their baseline. Drives the
  /// `Restrict` delete behavior — a snapshot in use as a baseline can't be
  /// removed without first detaching the period(s).
  reportingPeriods ReportingPeriod[]

  @@index([projectId, createdAt])
}

/// Origin of a measurement number. `MANUAL` is what the UI writes today;
/// `SPECTRUM` / `HEAVY_JOB` are reserved for future integrations so we can
/// tell auto-pulled values apart from PM-entered ones without a migration.
enum MeasurementSource {
  MANUAL
  SPECTRUM
  HEAVY_JOB
}

/// A point-in-time EVM cutoff for a project — typically monthly. Each period
/// is locked to a baseline snapshot so re-baselining doesn't retroactively
/// change last month's variance numbers.
model ReportingPeriod {
  id                 Int       @id @default(autoincrement())
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId          Int
  label              String
  /// The "as of" date — measurements describe work performed through here.
  dataDate           DateTime
  /// Required: the snapshot whose totals define BAC for this period.
  /// `Restrict` prevents deleting a snapshot that any period still depends on.
  baselineSnapshot   EstimateSnapshot @relation(fields: [baselineSnapshotId], references: [id], onDelete: Restrict)
  baselineSnapshotId Int
  createdById        Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  measurements       PeriodMeasurement[]

  @@unique([projectId, dataDate])
  @@index([projectId, dataDate])
}

/// One row per discipline-digit bucket per reporting period. Matches the
/// aggregation `accumulateProjectTotals` already produces (digit-bucketed)
/// so EVM rolls up the same way the rest of the app does.
model PeriodMeasurement {
  id                   Int               @id @default(autoincrement())
  period               ReportingPeriod   @relation(fields: [periodId], references: [id], onDelete: Cascade)
  periodId             Int
  /// "0".."9" — the leading digit of the CBS code bucket.
  bucket               String
  /// 0..1 fraction complete by the period's data date.
  percentComplete      Float             @default(0)
  /// $ actually incurred against this bucket through the data date.
  actualCost           Float             @default(0)
  /// Optional hours actually burned (for hours-based variance views).
  actualHours          Float?
  /// Optional manual PV override. When null, PV is derived time-linearly
  /// from project start/end + the period's data date.
  plannedValueOverride Float?
  source               MeasurementSource @default(MANUAL)
  notes                String            @default("")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@unique([periodId, bucket])
}

model CbsItem {
  id                 Int       @id @default(autoincrement())
  l1                 String
  l2                 String
  l3                 String
  l4                 String
  l5                 String
  l6                 String
  name               String
  displayCode        String
  uom                String
  accountDescription String
  l2Description      String?
  core               String?
  coreExtension      String?
  wbs                String?
  p6CostAccount      String?
  gl                 String?
  costTypePC         String?
  costTypeSpectrum   String?
  costCategory       String?
  discipline         String?
  subReporting       Boolean?
  costCode           String    @unique
  description        String?
  displayDescription String?
  allowedInProjects  Project[] @relation("ProjectAllowedFefCbsItems")

  // Hot path: discipline routes filter by `l1 IN (...)` on every load.
  @@index([l1])
}
